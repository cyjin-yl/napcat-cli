{
  "skills": [
    {
      "name": "napcat-cli",
      "description": "NapCat QQ bot messaging — send messages, read events, manage groups, handle friends",
      "enabled": true,
      "version": "1.0.0",
      "author": "Ezra",
      "license": "MIT",
      "platforms": [
        "linux"
      ],
      "metadata": {
        "source": "napcat-cli",
        "category": "messaging"
      },
      "allowedTools": [
        "read_file",
        "write_file",
        "list_directory"
      ],
      "exposeAtRoot": true,
      "bodyTemplateFile": "skills-fs.d/skill-body.md",
      "agentsTemplateFile": "skills-fs.d/skill-agents.md"
    }
  ],
  "mounts": [
    {
      "path": "/napcat",
      "kind": "dir",
      "mode": "0755"
    },
    {
      "path": "/persona.md",
      "kind": "blob",
      "mode": "0444",
      "dataFile": "skills-fs.d/persona.md"
    },
    {
      "path": "/napcat/groups",
      "kind": "dynamic_dir",
      "provider": "napcat",
      "read": "list_groups"
    },
    {
